# ─────────────────────────────────────────────────────────────
# .env.example — Copy this file to `.env` and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Sarvam AI ────────────────────────────────────────────────
# Get yours free at: https://cloud.sarvam.ai
SARVAM_API_KEY=

# ── Vector DB (Chroma) ──────────────────────────────────────
# Local directory for storing embeddings
CHROMA_PERSIST_DIR=./chroma_db

# ── Embedding Model ─────────────────────────────────────────
# Downloads automatically on first use (~80MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Ngrok (for public URL tunneling) ────────────────────────
NGROK_URL=https://vigintillionth-elmer-thanklessly.ngrok-free.dev

# ── Groq API (optional if using Groq LLM) ───────────────────
GROQ_API_KEY=

# ── LLM Provider ────────────────────────────────────────────
# Options: "openai" | "groq"
LLM_PROVIDER=groq

# ── OpenAI API Key (for GPT models) ─────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── LiveKit Cloud (for real-time audio streaming) ───────────
# Get from: https://cloud.livekit.io
LIVEKIT_URL=your_livekit_url_here
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── Vobiz SIP Trunk (Telephony Integration) ────────────────
# Get from: Vobiz Console → SIP Trunk Settings
VOBIZ_SIP_DOMAIN=your_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_vobiz_username
VOBIZ_PASSWORD=your_vobiz_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── SIP Trunk ID (Generated after setup) ───────────────────
OUTBOUND_TRUNK_ID=


CAL_API_KEY=
CAL_USERNAME=   
CAL_EVENT_SLUG=     
CAL_EVENT_TYPE_ID=
